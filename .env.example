# Copy this file to .env (which is gitignored) and fill in real values for local Docker usage.
# Do NOT commit a populated .env file.
# For non-Docker local development, prefer dotnet user-secrets (see README.md).

# PostgreSQL container settings (read by the postgres image at container init)
POSTGRES_DB=conterex_compliance
POSTGRES_USER=
POSTGRES_PASSWORD=

# Connection string used by the .NET app inside Docker
# When running via docker-compose the host is the service name "conterex_compliance.db".
DB_CONNECTION_STRING=Host=conterex_compliance.db;Port=5432;Database=conterex_compliance;User Id=<user>;Password=<password>

# JWT bearer settings
# SigningKey MUST be at least 32 characters of high-entropy random data.
JWT_ISSUER=https://localhost
JWT_AUDIENCE=Conterex.Compliance.Web
JWT_SIGNING_KEY=
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

# DEV-ONLY user that the stubbed IUserStore accepts at /api/auth/login.
# Remove this section entirely once a real identity module replaces DevUserStore.
DEV_USER_EMAIL=dev@example.com
DEV_USER_PASSWORD=
